{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@plantbase/core": ["packages/core/src/index.ts"],
      "@plantbase/db": ["packages/db/src/index.ts"]
    }
  }
}
